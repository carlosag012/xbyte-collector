#!/bin/sh
set -e

# Pre-removal scaffold for the xbyte-collector appliance package.
# Keep this minimal; avoid deleting data directories at this stage.

stop_services() {
  systemctl stop xbyte-collector.service 2>/dev/null || true
  systemctl stop xbyte-collector-bootstrap.service 2>/dev/null || true
}

case "$1" in
  remove|upgrade|deconfigure)
    stop_services
    ;;
esac

exit 0
